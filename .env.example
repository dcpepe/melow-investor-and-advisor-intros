# Database — PostgreSQL (e.g. Supabase).
# DATABASE_URL: the app's runtime connection. On Supabase use the *pooled* connection
#   string (Connect → Transaction pooler, port 6543) and append ?pgbouncer=true&connection_limit=1
# DIRECT_URL: the *direct* connection (port 5432), used by Prisma for migrations.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Auth — secret used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Base URL of the deployed portal (used to build invite links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# First admin user — used by `npm run db:seed` to create the initial admin account
ADMIN_EMAIL="pepe@melow.ai"
ADMIN_NAME="Pepe"
ADMIN_PASSWORD=""

# Email provider (optional). Resend-compatible HTTP API.
# If EMAIL_API_KEY is empty, invite emails are not sent — admins can copy invite links instead.
EMAIL_API_KEY=""
EMAIL_FROM="Melow <portal@melow.ai>"
